# Server
NODE_ENV=development
# IS_PRODUCTION: set to "true" to enable strict CORS, secure cookies, and CSP.
# Use this instead of relying solely on NODE_ENV so staging/preview envs can be
# fully secured without being named "production".
IS_PRODUCTION=false
PORT=3000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nvs_buildcon?retryWrites=true&w=majority

# JWT (REQUIRED — minimum 32 characters each, used in ALL environments)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_required
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_32_characters_required
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Password hashing
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# File uploads
MAX_FILE_SIZE_MB=10

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="NVS Buildcon" <noreply@nvsbuildcon.com>

# hCaptcha (https://www.hcaptcha.com — free tier available)
# Leave blank in local dev to skip CAPTCHA verification.
# REQUIRED before going live.
HCAPTCHA_SECRET=your_hcaptcha_secret_key
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# Frontend API base URL (used in Vite dev proxy and production fetch base)
# In production with a separate frontend host, set this to your backend URL.
# Leave blank when frontend and backend are served from the same Express server.
VITE_API_URL=

